<%= form.govuk_date_field :date_of_birth, date_of_birth: true, legend: nil, hint: { text: "For example, 31 3 1980" } %>

<h2 class="govuk-heading-s">Upload evidence</h2>
<p>Documents we accept</p>
<ul class="govuk-list govuk-list--bullet">
  <li>birth certificate</li>
  <li>passport</li>
  <li>driving license</li>
</ul>

<%=
  max_file_size = ActiveSupport::NumberHelper.number_to_human_size(Qualifications::OneLoginUsers::DateOfBirthChangeForm::MAX_SIZE).delete(" ")

  form.govuk_file_field(
    :evidence,
    label: { text: "Upload evidence", hidden: true, role: "link" },
    hint: { text: "You can upload a PDF, PNG or JPEG file no larger than #{max_file_size}." }
  )
%>

<%= form.govuk_submit "Continue" %>
