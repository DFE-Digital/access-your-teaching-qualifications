<%= form.govuk_text_field :first_name, autocomplete: "given-name", label: { text: "First name" } %>
<%= form.govuk_text_field :middle_name, autocomplete: "additional-name", label: { text: "Middle name" }, hint_text: "Optional" %>
<%= form.govuk_text_field :last_name, autocomplete: "family-name", label: { text: "Last name" } %>

<h2 class="govuk-heading-s">Upload evidence</h2>
<p>Documents we accept</p>
<ul class="govuk-list govuk-list--bullet">
  <li> marriage certificate </li>
  <li> civil partnership certificate </li>
  <li> decree absolute and birth certificate </li>
  <li> statutory declaration </li>
  <li> deed poll </li>
</ul>

<%=
  max_file_size = ActiveSupport::NumberHelper.number_to_human_size(Qualifications::OneLoginUsers::NameChangeForm::MAX_SIZE).delete(" ")

  form.govuk_file_field(
    :evidence,
    label: { text: "Upload evidence", hidden: true, role: "link" },
    hint: { text: "You can upload a PDF, PNG or JPEG file no larger than #{max_file_size}." }
  )
%>

<%= form.govuk_submit "Continue" %>
